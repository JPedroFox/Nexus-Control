<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_launcher.xml
    Caminho: res/mipmap-anydpi-v26/ic_launcher.xml

    Adaptive icon — introduzido no Android 8.0 (API 26).
    O launcher recorta o ícone na forma que quiser (círculo, squircle, etc.)
    usando foreground + background como camadas separadas.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>