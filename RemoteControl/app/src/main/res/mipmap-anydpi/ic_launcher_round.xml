<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_launcher_round.xml
    Caminho: res/mipmap-anydpi-v26/ic_launcher_round.xml

    Variante circular do adaptive icon.
    Launchers como o do Pixel usam este arquivo quando o usuário
    escolhe ícones redondos. O conteúdo é idêntico ao ic_launcher.xml —
    o recorte circular fica por conta do launcher.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>