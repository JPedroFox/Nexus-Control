<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="?attr/selectableItemBackground"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:gravity="center_vertical">

    <!-- Infos do processo -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="12dp">

        <!-- Nome do processo -->
        <TextView
            android:id="@+id/tvNome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <!-- PID + Memória -->
        <TextView
            android:id="@+id/tvDetalhes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#BDBDBD"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginTop="2dp"/>

        <!-- Título da janela (opcional) -->
        <TextView
            android:id="@+id/tvJanela"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#9FA8DA"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- Botão encerrar -->
    <Button
        android:id="@+id/btnKill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_kill"
        android:textSize="11sp"
        android:backgroundTint="#7F0000"
        android:textColor="#FFFFFF"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        tools:ignore="VisualLintSystemUi"/>

</LinearLayout>