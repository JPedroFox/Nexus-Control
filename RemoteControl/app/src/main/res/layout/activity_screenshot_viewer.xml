<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- Imagem com zoom/pan ocupa toda a tela -->
    <com.remotecontrol.app.ZoomableImageView
        android:id="@+id/zoomableImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="#000000"/>

    <!-- Barra superior -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#E6000000"
        android:paddingStart="4dp"
        android:paddingEnd="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_close"
            app:tint="#FFFFFF"
            android:padding="12dp"/>

        <!-- Label "MONITOR X" -->
        <TextView
            android:id="@+id/tvInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/loading"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.05"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"/>

        <ImageButton
            android:id="@+id/btnSave"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_save"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_save"
            app:tint="#00E5FF"
            android:padding="12dp"/>

    </LinearLayout>

    <!-- Barra inferior: nav anterior / contador / próximo -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#E6000000"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnPrev"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="@string/cd_prev"
            app:tint="#FFFFFF"
            android:padding="16dp"/>

        <TextView
            android:id="@+id/tvCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/counter_placeholder"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"/>

        <ImageButton
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_media_next"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="@string/cd_next"
            app:tint="#FFFFFF"
            android:padding="16dp"/>

    </LinearLayout>

    <!-- Dica de gesto — centralizada acima da bottom bar -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/gesture_hint"
        android:textColor="#CCFFFFFF"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.05"
        android:background="#99000000"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>