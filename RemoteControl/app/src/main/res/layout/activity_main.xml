<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp">

        <!-- ── HEADER ──────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REMOTE"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.25"
                android:fontFamily="monospace"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTROL"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#00E5FF"
                android:letterSpacing="0.25"
                android:fontFamily="monospace"
                android:layout_marginTop="-8dp"/>

            <View
                android:layout_width="48dp"
                android:layout_height="2dp"
                android:background="#00E5FF"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- ── CONEXÃO ─────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#00E5FF"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONEXÃO"
                    android:textColor="#00E5FF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <EditText
                    android:id="@+id/etIp"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="3"
                    android:hint="192.168.1.100"
                    android:inputType="text"
                    android:textColor="#E0E0E0"
                    android:textColorHint="#404050"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/input_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginEnd="8dp"/>

                <EditText
                    android:id="@+id/etPort"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:hint="8888"
                    android:inputType="number"
                    android:textColor="#E0E0E0"
                    android:textColorHint="#404050"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/input_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnConnect"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="CONECTAR"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:fontFamily="monospace"
                android:backgroundTint="#00E5FF"
                android:textColor="#0A0A0F"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="● DESCONECTADO"
                android:textColor="#FF5252"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:letterSpacing="0.05"/>
        </LinearLayout>

        <!-- ── VOLUME ───────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#7C4DFF"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VOLUME"
                    android:textColor="#7C4DFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnVolDown"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="🔉"
                    android:textSize="22sp"
                    android:backgroundTint="#16161F"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnMute"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="🔇"
                    android:textSize="22sp"
                    android:backgroundTint="#16161F"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnVolUp"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="🔊"
                    android:textSize="22sp"
                    android:backgroundTint="#16161F"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ── MÍDIA ────────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#00E676"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MÍDIA"
                    android:textColor="#00E676"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnPrev"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="⏮"
                    android:textSize="22sp"
                    android:backgroundTint="#16161F"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnPlay"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:text="⏯"
                    android:textSize="26sp"
                    android:backgroundTint="#1A2A1A"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnNext"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="⏭"
                    android:textSize="22sp"
                    android:backgroundTint="#16161F"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ── SCREENSHOT ───────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#FF6D00"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TELA DO PC"
                    android:textColor="#FF6D00"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnScreenshot"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="📸  CAPTURAR TELA"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:fontFamily="monospace"
                android:backgroundTint="#1A1200"
                android:textColor="#FF6D00"/>
        </LinearLayout>

        <!-- ── SISTEMA ──────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#FF1744"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SISTEMA"
                    android:textColor="#FF1744"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnLock"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="🔒"
                    android:textSize="20sp"
                    android:backgroundTint="#16161F"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnRestart"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="🔄"
                    android:textSize="20sp"
                    android:backgroundTint="#1A0D00"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnShutdown"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="⏻"
                    android:textSize="20sp"
                    android:backgroundTint="#1F0000"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>