<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:scrollbars="none"
    android:clipToPadding="false"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp">

        <!-- ── HEADER ──────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_remote"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.25"
                android:fontFamily="monospace"
                tools:ignore="VisualLintSystemUi" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_control"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#00E5FF"
                android:letterSpacing="0.25"
                android:fontFamily="monospace"
                android:layout_marginTop="-8dp"/>

            <View
                android:layout_width="48dp"
                android:layout_height="2dp"
                android:background="#00E5FF"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- ── CONNECTION ──────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#00E5FF"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_conexao"
                    android:textColor="#00E5FF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <EditText
                    android:id="@+id/etIp"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="3"
                    android:hint="@string/hint_ip"
                    android:autofillHints="no"
                    android:inputType="text"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#AAAAAA"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/input_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginEnd="8dp"
                    tools:ignore="VisualLintTextFieldSize" />

                <EditText
                    android:id="@+id/etPort"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:hint="@string/hint_port"
                    android:autofillHints="no"
                    android:inputType="number"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#AAAAAA"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/input_bg"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnConnect"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:maxWidth="320dp"
                android:layout_gravity="center_horizontal"
                android:text="@string/btn_conectar"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:fontFamily="monospace"
                app:backgroundTint="#00E5FF"
                android:textColor="#000000"
                android:layout_marginBottom="12dp"
                tools:ignore="VisualLintButtonSize" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/status_disconnected"
                android:textColor="#FF8A80"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:letterSpacing="0.05"/>
        </LinearLayout>

        <!-- ── VOLUME ───────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#B388FF"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_volume"
                    android:textColor="#B388FF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                tools:ignore="ButtonStyle">

                <Button
                    android:id="@+id/btnVolDown"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/btn_vol_down"
                    android:textSize="22sp"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#16161F"
                    android:layout_marginEnd="6dp"
                    tools:ignore="VisualLintButtonSize" />

                <Button
                    android:id="@+id/btnMute"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/btn_mute"
                    android:textSize="22sp"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#16161F"
                    android:layout_marginEnd="6dp"
                    tools:ignore="VisualLintButtonSize" />

                <Button
                    android:id="@+id/btnVolUp"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/btn_vol_up"
                    android:textSize="22sp"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#16161F"
                    tools:ignore="VisualLintButtonSize" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── MEDIA ────────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#00E676"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_midia"
                    android:textColor="#00E676"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <!--
                Row 1: transport controls
                [-10s]  [⏮]  [⏯]  [⏭]  [+10s]
                Skip buttons are smaller weight so the play button stays prominent.
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                android:layout_marginBottom="0dp"
                tools:ignore="ButtonStyle">

                <!-- -10s -->
                <Button
                    android:id="@+id/btnSkipBack"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1.2"
                    android:text="@string/btn_skip_back"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#00E676"
                    app:backgroundTint="#0A1A0A"
                    android:layout_marginEnd="4dp"
                    tools:ignore="VisualLintButtonSize" />

                <!-- Previous track -->
                <Button
                    android:id="@+id/btnPrev"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/btn_prev"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#16161F"
                    android:layout_marginEnd="4dp"
                    tools:ignore="VisualLintButtonSize" />

                <!-- Play / Pause — slightly taller to stand out -->
                <Button
                    android:id="@+id/btnPlay"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1.4"
                    android:text="@string/btn_play"
                    android:textSize="26sp"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#1A2A1A"
                    android:layout_marginEnd="4dp"
                    tools:ignore="VisualLintButtonSize" />

                <!-- Next track -->
                <Button
                    android:id="@+id/btnNext"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/btn_next"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#16161F"
                    android:layout_marginEnd="4dp"
                    tools:ignore="VisualLintButtonSize" />

                <!-- +10s -->
                <Button
                    android:id="@+id/btnSkipFwd"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1.2"
                    android:text="@string/btn_skip_fwd"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#00E676"
                    app:backgroundTint="#0A1A0A"
                    tools:ignore="VisualLintButtonSize" />

            </LinearLayout>
        </LinearLayout>

        <!-- ── SCREENSHOT ───────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#FF6D00"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_tela"
                    android:textColor="#FF6D00"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnScreenshot"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:maxWidth="320dp"
                android:layout_gravity="center_horizontal"
                android:text="@string/btn_screenshot"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:fontFamily="monospace"
                app:backgroundTint="#1A1200"
                android:textColor="#FFB74D"
                tools:ignore="VisualLintButtonSize" />
        </LinearLayout>

        <!-- ── SYSTEM ───────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="14dp"
                    android:background="#FF1744"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_sistema"
                    android:textColor="#FF1744"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                tools:ignore="ButtonStyle">

                <Button
                    android:id="@+id/btnLock"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="@string/btn_lock"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#16161F"
                    android:layout_marginEnd="6dp"
                    tools:ignore="VisualLintButtonSize" />

                <Button
                    android:id="@+id/btnRestart"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="@string/btn_restart"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#1A0D00"
                    android:layout_marginEnd="6dp"
                    tools:ignore="VisualLintButtonSize" />

                <Button
                    android:id="@+id/btnShutdown"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="@string/btn_shutdown"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#1F0000"
                    tools:ignore="VisualLintButtonSize" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── PROCESSES ────────────────────────────────────────────────── -->
        <Button
            android:id="@+id/btnProcessos"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:maxWidth="320dp"
            android:layout_gravity="center_horizontal"
            android:text="@string/btn_processos"
            app:backgroundTint="#1A1A2E"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:layout_marginTop="12dp"
            tools:ignore="VisualLintButtonSize" />

        <!-- ── MOUSE & KEYBOARD ─────────────────────────────────────────── -->
        <Button
            android:id="@+id/btnMouseKeyboard"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:maxWidth="320dp"
            android:layout_gravity="center_horizontal"
            android:text="@string/btn_mouse_keyboard"
            app:backgroundTint="#0D1A0D"
            android:textColor="#69F0AE"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            tools:ignore="VisualLintButtonSize" />

    </LinearLayout>
</ScrollView>